# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://agripay:agripay_dev@localhost:5432/agri_pay

# ── BTCPay Server ─────────────────────────────────────────────────────────────
BTCPAY_URL=https://your-btcpay.server
BTCPAY_API_KEY=your_api_key
BTCPAY_STORE_ID=your_store_id
# Generate with: openssl rand -hex 32
BTCPAY_WEBHOOK_SECRET=your_webhook_secret

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Must be at least 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET=q40Mwgb3DY8Cr5RIqpsHNGylnEhxWf7FkuilCO9SnBBLnT8ogeIfibWC8wGcduHE
JWT_EXPIRY_HOURS=24

# Admin credentials
# Hash with: htpasswd -bnBC 12 "" yourpassword | tr -d ':\n'
ADMIN_PASSWORD_HASH=$2b$12$replace_with_real_bcrypt_hash

# ── M-Pesa Daraja ─────────────────────────────────────────────────────────────
MPESA_ENV=sandbox                # sandbox | production
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=600998
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=Safaricom999!*!
# Production only: path to PEM public key extracted from Safaricom's production cert.
# Extract with: openssl x509 -pubkey -noout -in ProductionCertificate.cer > mpesa_prod_pubkey.pem
MPESA_CERT_PATH=

# ── Webhook callback URLs ─────────────────────────────────────────────────────
# BASE_URL must be publicly reachable so Safaricom can POST results back.
BASE_URL=http://localhost:3001
# Secret token embedded in M-Pesa callback URLs to authenticate Safaricom callbacks.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=dev-webhook-secret

# ── FX Oracle ─────────────────────────────────────────────────────────────────
COINGECKO_API_URL=https://api.coingecko.com/api/v3
RATE_CACHE_SECONDS=60
MAX_RATE_STALE_SECS=3600

# ── Background Workers ────────────────────────────────────────────────────────
# Seconds after creation that invoice_created payments are marked failed
INVOICE_EXPIRY_SECS=86400
# How often the expiry worker runs (seconds)
EXPIRY_INTERVAL_SECS=600
# How often the reconciliation worker runs (seconds)
RECONCILE_INTERVAL_SECS=300
# Seconds a disbursing_mpesa withdrawal is considered stuck
DISBURSE_STALE_SECS=1800

# ── CORS & Security ───────────────────────────────────────────────────────────
# Comma-separated origins allowed by CORS. Use "*" to allow any (dev only).
ALLOWED_ORIGINS=http://localhost:5173

# ── Observability ─────────────────────────────────────────────────────────────
# "json" for structured production logs; "text" for human-readable dev logs.
LOG_FORMAT=text
RUST_LOG=agri_pay=debug,tower_http=debug
