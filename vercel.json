{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "static",
  "framework": null,
  "build": {
    "env": {
      "VITE_BASE_PATH": "/"
    }
  },
  "rewrites": [
    {
      "source": "/((?!assets/)(?!.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
